rules_version = '2';

// Cada usuário acessa os próprios dados. Além disso, alguém convidado (membro)
// pode acessar os dados do dono que o convidou.
service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(ownerUid) {
      return exists(/databases/$(database)/documents/users/$(ownerUid)/members/$(request.auth.uid));
    }

    // Dados financeiros: dono OU membro com acesso.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isMember(userId));
    }

    // Reivindicar a própria associação (o membro ainda não é membro — precisa de regra própria).
    match /users/{ownerUid}/members/{memberUid} {
      allow read: if request.auth != null && (request.auth.uid == ownerUid || request.auth.uid == memberUid);
      allow create: if request.auth != null && request.auth.uid == memberUid
        && get(/databases/$(database)/documents/invites/$(request.auth.token.email)).data.ownerUid == ownerUid;
      allow delete: if request.auth != null && (request.auth.uid == ownerUid || request.auth.uid == memberUid);
    }

    // Perfis: qualquer logado lê (para o painel de admin e resolução de e-mail); cada um edita o seu.
    match /profiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Convites por e-mail.
    match /invites/{email} {
      allow read, write: if request.auth != null;
    }
  }
}
